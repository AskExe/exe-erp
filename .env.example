# ──────────────────────────────────────────────────────────────
# Exe ERP — Environment Variables
# Copy to .env and configure for your deployment
# ──────────────────────────────────────────────────────────────

# ── Database (exe-erp's own database on the shared PostgreSQL server) ──
POSTGRES_PASSWORD=changeme_postgres_password
ERP_ADMIN_PASSWORD=changeme_admin_password

# DB_HOST=exe-db           # Docker service name (default)
# DB_PORT=5432             # PostgreSQL port (default)
# DB_TYPE=postgres         # Always postgres for exe-erp
# DB_NAME=exe_erp          # exe-erp's own database (NOT exedb)

# ── Redis ─────────────────────────────────────────────────────
# REDIS_CACHE=redis://redis:6379/3      # Cache (db 3)
# REDIS_QUEUE=redis://redis:6379/4      # RQ job queue (db 4)
# REDIS_SOCKETIO=redis://redis:6379/5   # Socket.io realtime (db 5)

# ── Exe Bridge (cross-database event emission to exedb) ──────
# Connection to the shared exedb instance for raw.raw_events writes.
# If not set, constructs from DB_HOST + defaults.
# EXE_BRIDGE_DATABASE_URL=postgresql://exe:password@exe-db:5432/exedb

# Disable bridge entirely (events won't flow to landing pad):
# EXE_BRIDGE_DISABLED=true   # Set in site_config.json as exe_bridge_disabled

# ── Exe Monitor (error forwarding) ───────────────────────────
# MONITOR_ERROR_URL=http://exe-monitor-hub:8090/api/exe-monitor/errors
# MONITOR_API_KEY=changeme_monitor_api_key
# ERROR_REPORTING_ENABLED=true   # Set to "false" to disable

# ── Sentry (error tracking) ──────────────────────────────────
# FRAPPE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
# ENABLE_SENTRY_DB_MONITORING=true
# SENTRY_TRACING_SAMPLE_RATE=0.1
# SENTRY_PROFILING_SAMPLE_RATE=0.3

# ── GoTrue SSO ────────────────────────────────────────────────
# Configured in site_config.json, not env vars:
#   "gotrue_url": "http://gotrue:9999"
#   "exe_admin_token": "your-secret-shared-token"

# ── Site ──────────────────────────────────────────────────────
# SITE_NAME is the Frappe site name (also used for SSO domain derivation).
# Customers MUST set this to their own domain (e.g. erp.acme.com).
SITE_NAME=erp.localhost
